#!/usr/bin/env bash
# Stop hook: parse transcript JSONL, compute token delta, inject into Worker

set -euo pipefail

# Read stdin JSON and extract transcript_path
input=$(cat)
transcript_path=$(printf '%s' "$input" | node -e "
  let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
    try{const o=JSON.parse(d); process.stdout.write(o.transcript_path||'')}catch{process.stdout.write('')}
  })
")

[ -z "$transcript_path" ] && exit 0
[ ! -f "$transcript_path" ] && exit 0

# Parse JSONL, sum all assistant message token usage
total=$(node -e "
const fs=require('fs');
let total=0;
try{
  const lines=fs.readFileSync(process.argv[1],'utf8').split('\n');
  for(const line of lines){
    if(!line.trim())continue;
    try{
      const o=JSON.parse(line);
      if(o.type==='assistant'){
        const u=(o.message&&o.message.usage)||{};
        total+=(u.input_tokens||0)+(u.output_tokens||0);
      }
    }catch{}
  }
}catch{}
process.stdout.write(String(total));
" "$transcript_path")

[ -z "$total" ] && exit 0
[ "$total" -eq 0 ] && exit 0

# Read previous state
STATE_FILE="$HOME/.tokensyber/state.json"
prev=0
last_transcript=""
if [ -f "$STATE_FILE" ]; then
  prev=$(node -e "try{process.stdout.write(String(JSON.parse(require('fs').readFileSync(process.argv[1],'utf8')).lastTokens||0))}catch{process.stdout.write('0')}" "$STATE_FILE")
  last_transcript=$(node -e "try{process.stdout.write(JSON.parse(require('fs').readFileSync(process.argv[1],'utf8')).lastTranscript||'')}catch{process.stdout.write('')}" "$STATE_FILE")
fi

# New session: reset prev
[ "$transcript_path" != "$last_transcript" ] && prev=0

delta=$((total - prev))
[ "$delta" -le 0 ] && exit 0

# Read player credentials
PLAYER_FILE="$HOME/.tokensyber/player.json"
[ ! -f "$PLAYER_FILE" ] && exit 0

PLAYER_ID=$(node -e "try{process.stdout.write(JSON.parse(require('fs').readFileSync(process.argv[1],'utf8')).playerId)}catch{process.stdout.write('')}" "$PLAYER_FILE")
HMAC_KEY=$(node -e "try{process.stdout.write(JSON.parse(require('fs').readFileSync(process.argv[1],'utf8')).hmacKey)}catch{process.stdout.write('')}" "$PLAYER_FILE")

[ -z "$PLAYER_ID" ] && exit 0

# Compute HMAC signature: HMAC-SHA256(hmacKey, "playerId:delta")
SIG=$(node -e "
const crypto = require('crypto');
const key = process.argv[1];
const msg = process.argv[2];
process.stdout.write(crypto.createHmac('sha256', key).update(msg).digest('hex'));
" "$HMAC_KEY" "${PLAYER_ID}:${delta}")

# Inject tokens via Worker (retry once on failure for cold starts)
WORKER_URL="https://tokensyber.pages.dev"
inject_result=""
for attempt in 1 2; do
  inject_result=$(curl -s --connect-timeout 10 --max-time 15 "${WORKER_URL}/fuel-inject?player=${PLAYER_ID}&tokens=${delta}&sig=${SIG}" 2>/dev/null || echo "")
  if [ -n "$inject_result" ]; then
    if printf '%s' "$inject_result" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const o=JSON.parse(d);if(o.ok||o.error)process.stdout.write('ok')}catch{process.stdout.write('0')}})" 2>/dev/null | grep -q ok; then
      break
    fi
  fi
  [ "$attempt" = "1" ] && sleep 1
done

# Update state
mkdir -p "$HOME/.tokensyber"
node -e "
const fs=require('fs');
const f=process.argv[1];
const delta=${delta};
let s={};
try{s=JSON.parse(fs.readFileSync(f,'utf8'))}catch{}
s.lastTokens=${total};
s.injectedTokens=(s.injectedTokens||0)+delta;
s.lastTranscript=process.argv[2];
fs.writeFileSync(f,JSON.stringify(s));
" "$STATE_FILE" "$transcript_path"
