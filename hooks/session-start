#!/usr/bin/env bash
# SessionStart hook: init player state, generate player ID if absent

set -euo pipefail

STATE_DIR="$HOME/.tokensyber"
mkdir -p "$STATE_DIR"

# Clear cached token count so statusline fallback shows 0 for new context
echo '{"lastTokens":0,"injectedTokens":0}' > "$STATE_DIR/state.json"

# Generate player.json if absent (contains playerId + hmacKey for Worker auth)
PLAYER_FILE="$STATE_DIR/player.json"
if [ ! -f "$PLAYER_FILE" ]; then
  PLAYER_ID=$(node -e "process.stdout.write(require('crypto').randomUUID())")
  HMAC_KEY=$(node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))")
  echo "{\"playerId\":\"$PLAYER_ID\",\"hmacKey\":\"$HMAC_KEY\",\"createdAt\":$(date +%s%3N)}" > "$PLAYER_FILE"
fi
